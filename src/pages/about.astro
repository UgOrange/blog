---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { AUTHOR } from "../consts";
import { useTranslations } from "../i18n/utils";

const t = useTranslations("zh");
---

<!doctype html>
<html lang="zh">
  <head>
    <BaseHead title={t("about.title")} description={t("about.description")} />
    <style>
      main {
        width: 960px;
        max-width: calc(100% - 2em);
        margin: 0 auto;
        padding: 2em 1em;
      }
      .about-content {
        max-width: 720px;
        margin: 0 auto;
      }
      .about-content h1 {
        margin-bottom: 1em;
      }
      .about-content p {
        margin-bottom: 1.5em;
        line-height: 1.8;
        color: rgb(var(--gray-dark));
      }
      .contact-links {
        margin-top: 2em;
        padding-top: 2em;
        border-top: 1px solid rgb(var(--gray-light));
      }
      .contact-links h2 {
        margin-bottom: 1em;
      }
      .contact-links ul {
        list-style: none;
        padding: 0;
      }
      .contact-links li {
        margin-bottom: 0.5em;
      }
      .contact-links a {
        color: var(--accent);
        text-decoration: none;
      }
      .contact-links a:hover {
        text-decoration: underline;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <div class="about-content">
        <h1>{t("about.title")}</h1>
        <p>
          你好！我是 {AUTHOR.name}，一名热爱技术的开发者。欢迎来到我的个人博客！
        </p>
        <p>
          在这里，我会分享我在软件开发、技术探索和日常生活中的所思所想。我相信分享知识是最好的学习方式，希望我的文章能对你有所帮助。
        </p>
        <p>
          我对各种技术都充满好奇，尤其是 Web 开发、系统设计和开发工具。如果你有任何问题或想法，欢迎通过以下方式联系我。
        </p>

        <div class="contact-links">
          <h2>联系方式</h2>
          <ul>
            <li>
              📧 邮箱：<a href={`mailto:${AUTHOR.email}`}>{AUTHOR.email}</a>
            </li>
            <li>
              🐙 GitHub：<a href={`https://github.com/${AUTHOR.github}`} target="_blank"
                >@{AUTHOR.github}</a
              >
            </li>
            <li>
              🌐 网站：<a href={AUTHOR.website} target="_blank">{AUTHOR.website}</a>
            </li>
          </ul>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>
